<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Parachute — NVC Pitch Deck</title>
    <meta name="robots" content="noindex">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&family=JetBrains+Mono:wght@400&display=swap">
    <style>
        :root {
            --bg:           #faf8f4;
            --bg-soft:      #f3f0ea;
            --fg:           #2c2a26;
            --fg-muted:     #6b6860;
            --fg-dim:       #9a9690;
            --accent:       #4a7c59;
            --accent-soft:  rgba(74, 124, 89, 0.08);
            --accent-light: #6a9b77;
            --border:       #e4e0d8;
            --serif: 'Instrument Serif', Georgia, serif;
            --sans:  'DM Sans', system-ui, sans-serif;
            --mono:  'JetBrains Mono', monospace;
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; scroll-snap-type: y mandatory; }

        body {
            background: var(--bg);
            font-family: var(--sans);
            color: var(--fg);
            -webkit-font-smoothing: antialiased;
            line-height: 1.6;
        }

        /* -- Slide structure -- */
        .slide {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 4rem 6rem;
            border-bottom: 1px solid var(--border);
            scroll-snap-align: start;
            position: relative;
        }
        .slide:last-child { border-bottom: none; }

        .slide-label {
            font-size: 0.65rem;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--accent);
            font-weight: 500;
            margin-bottom: 1.5rem;
        }

        .slide-headline {
            font-family: var(--serif);
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 400;
            letter-spacing: -0.02em;
            line-height: 1.08;
            color: var(--fg);
            margin-bottom: 2rem;
        }
        .slide-headline em {
            font-style: italic;
            color: var(--fg-muted);
        }

        .slide-body {
            color: var(--fg-muted);
            max-width: 720px;
        }
        .slide-body p {
            font-size: 1.15rem;
            line-height: 1.7;
            margin-bottom: 1rem;
        }
        .slide-body p:last-child { margin-bottom: 0; }
        .slide-body strong { color: var(--fg); font-weight: 500; }

        /* -- Stat row -- */
        .stat-row {
            display: flex;
            gap: 0;
            margin: 1.5rem 0;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            max-width: 500px;
        }
        .stat {
            flex: 1;
            padding: 1.5rem;
            border-right: 1px solid var(--border);
            text-align: center;
        }
        .stat:last-child { border-right: none; }
        .stat-num {
            font-family: var(--serif);
            font-size: 2.5rem;
            color: var(--accent);
            line-height: 1;
            letter-spacing: -0.03em;
            margin-bottom: 0.4rem;
        }
        .stat-label {
            font-size: 0.75rem;
            color: var(--fg-muted);
            line-height: 1.4;
        }

        /* -- Flywheel -- */
        .flywheel {
            display: flex;
            flex-direction: column;
            max-width: 500px;
            margin: 1rem 0;
        }
        .fw-step {
            font-family: var(--serif);
            font-size: 1.35rem;
            color: var(--fg);
            padding: 0.85rem 0;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .fw-step:first-child { border-top: 1px solid var(--border); }
        .fw-step.final { color: var(--accent); }
        .fw-num {
            font-family: var(--mono);
            font-size: 0.65rem;
            color: var(--fg-dim);
            letter-spacing: 0.06em;
            flex-shrink: 0;
            width: 1.5rem;
        }

        /* -- Tier table -- */
        .tier-table {
            margin: 1rem 0;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            max-width: 600px;
        }
        .tier-row {
            display: flex;
            align-items: baseline;
            gap: 1.25rem;
            padding: 0.7rem 1.25rem;
            border-bottom: 1px solid var(--border);
        }
        .tier-row:last-child { border-bottom: none; }
        .tier-price {
            font-family: var(--serif);
            font-size: 1.5rem;
            color: var(--accent);
            min-width: 5rem;
            flex-shrink: 0;
        }
        .tier-price span { font-family: var(--sans); font-size: 0.75rem; color: var(--fg-dim); }
        .tier-body { font-size: 0.9rem; color: var(--fg-muted); }
        .tier-body strong { color: var(--fg); font-weight: 500; }
        .tier-highlight { background: var(--accent-soft); }

        /* -- Financial table -- */
        .fin-table {
            margin: 1rem 0;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            max-width: 700px;
        }
        .fin-table table {
            width: 100%;
            border-collapse: collapse;
        }
        .fin-table th {
            font-size: 0.7rem;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: var(--fg-dim);
            font-weight: 500;
            text-align: center;
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--border);
            background: var(--bg-soft);
        }
        .fin-table th:first-child { text-align: left; }
        .fin-table td {
            font-size: 0.9rem;
            color: var(--fg-muted);
            padding: 0.65rem 1rem;
            border-bottom: 1px solid var(--border);
            text-align: center;
        }
        .fin-table td:first-child {
            font-weight: 500;
            color: var(--fg);
            text-align: left;
            font-size: 0.85rem;
        }
        .fin-table tr:last-child td { border-bottom: none; }
        .fin-table .highlight { color: var(--accent); font-weight: 500; }

        /* -- Ask box -- */
        .ask-box {
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            margin: 1rem 0;
            max-width: 500px;
        }
        .ask-row {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            padding: 0.9rem 1.25rem;
            border-bottom: 1px solid var(--border);
        }
        .ask-row:last-child { border-bottom: none; }
        .ask-row .lbl { font-size: 0.85rem; color: var(--fg-muted); }
        .ask-row .val { font-family: var(--serif); font-size: 1.1rem; color: var(--fg); }

        .close-quote {
            font-family: var(--serif);
            font-size: clamp(1.5rem, 3vw, 2rem);
            color: var(--fg);
            margin-top: 2.5rem;
            line-height: 1.3;
            max-width: 550px;
        }
        .close-links {
            margin-top: 1.5rem;
            font-size: 0.85rem;
            color: var(--fg-dim);
        }
        .close-links a {
            color: var(--accent);
            text-decoration: none;
        }
        .close-links a:hover { text-decoration: underline; }

        /* -- Architecture diagram (hub-and-spoke) -- */
        .arch-diagram {
            margin: 1rem 0;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            max-width: 650px;
            padding: 1.5rem 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0;
        }
        .arch-spoke {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        .arch-spoke-label {
            font-family: var(--mono);
            font-size: 0.6rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--fg-dim);
            margin-bottom: 0.25rem;
        }
        .arch-spoke.right { align-items: flex-end; }
        .arch-spoke.right .arch-spoke-label { text-align: right; }
        .arch-box {
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 0.4rem 0.9rem;
            font-size: 0.8rem;
            color: var(--fg);
            background: var(--bg);
            white-space: nowrap;
        }
        .arch-hub {
            border: 2px solid var(--accent);
            background: var(--accent-soft);
            color: var(--accent);
            font-weight: 500;
            border-radius: 10px;
            padding: 1rem 1.25rem;
            text-align: center;
            font-size: 0.85rem;
            line-height: 1.5;
            flex-shrink: 0;
            margin: 0 0.25rem;
        }
        .arch-hub strong {
            display: block;
            font-size: 0.95rem;
        }
        .arch-connector {
            font-family: var(--mono);
            font-size: 0.75rem;
            color: var(--fg-dim);
            padding: 0 0.5rem;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.15rem;
        }
        .arch-connector .conn-label {
            font-size: 0.55rem;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        /* -- Competitor landscape -- */
        .landscape {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0;
            max-width: 700px;
            margin: 1.5rem 0;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
        }
        .landscape-quadrant {
            padding: 1.5rem;
            border-right: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
        }
        .landscape-quadrant:nth-child(2n) { border-right: none; }
        .landscape-quadrant:nth-child(n+3) { border-bottom: none; }
        .landscape-quadrant .quad-label {
            font-size: 0.6rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--fg-dim);
            font-weight: 500;
            margin-bottom: 0.75rem;
        }
        .landscape-quadrant .quad-names {
            font-family: var(--serif);
            font-size: 1.1rem;
            color: var(--fg-muted);
            line-height: 1.8;
        }
        .landscape-quadrant.ours {
            background: var(--accent-soft);
        }
        .landscape-quadrant.ours .quad-label { color: var(--accent); }
        .landscape-quadrant.ours .quad-names { color: var(--accent); font-weight: 500; }

        /* -- Persona cards -- */
        .persona-row {
            display: flex;
            gap: 1.5rem;
            margin: 1.5rem 0;
            max-width: 900px;
        }
        .persona-card {
            flex: 1;
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1.75rem;
            background: #fff;
        }
        .persona-card .persona-icon {
            font-size: 2rem;
            margin-bottom: 0.75rem;
        }
        .persona-card .persona-who {
            font-family: var(--serif);
            font-size: 1.2rem;
            color: var(--fg);
            margin-bottom: 0.5rem;
        }
        .persona-card .persona-how {
            font-size: 0.9rem;
            color: var(--fg-muted);
            line-height: 1.6;
        }

        /* -- GTM channels -- */
        .gtm-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin: 1.5rem 0;
            max-width: 800px;
        }
        .gtm-item {
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1.25rem;
            background: #fff;
        }
        .gtm-item .gtm-name {
            font-family: var(--serif);
            font-size: 1.1rem;
            color: var(--fg);
            margin-bottom: 0.35rem;
        }
        .gtm-item .gtm-desc {
            font-size: 0.8rem;
            color: var(--fg-muted);
            line-height: 1.5;
        }

        /* -- Mobile -- */
        @media (max-width: 768px) {
            .slide { padding: 3rem 1.5rem; }
            .stat-row { flex-direction: column; }
            .stat { border-right: none; border-bottom: 1px solid var(--border); }
            .stat:last-child { border-bottom: none; }
            .landscape { grid-template-columns: 1fr; }
            .landscape-quadrant { border-right: none !important; border-bottom: 1px solid var(--border) !important; }
            .landscape-quadrant:last-child { border-bottom: none !important; }
            .persona-row { flex-direction: column; }
            .gtm-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- Download bar -->
    <div style="position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--bg); border-bottom: 1px solid var(--border); padding: 0.75rem 2rem; display: flex; align-items: center; justify-content: space-between;">
        <span style="font-family: var(--serif); font-size: 0.95rem; color: var(--fg);">Parachute &mdash; NVC Pitch Deck</span>
        <div style="display: flex; gap: 0.75rem;">
            <a href="/nvc/ES_Parachute.pdf" download style="padding: 0.35rem 0.75rem; background: var(--accent); color: #fff; border-radius: 5px; text-decoration: none; font-size: 0.75rem; font-weight: 500;">Executive Summary (PDF)</a>
            <a href="/nvc/Parachute.pptx" download style="padding: 0.35rem 0.75rem; background: var(--accent); color: #fff; border-radius: 5px; text-decoration: none; font-size: 0.75rem; font-weight: 500;">Pitch Deck (PPTX)</a>
            <a href="/nvc/" style="padding: 0.35rem 0.75rem; background: var(--bg-soft); color: var(--fg); border: 1px solid var(--border); border-radius: 5px; text-decoration: none; font-size: 0.75rem; font-weight: 500;">Full Summary</a>
        </div>
    </div>

    <!-- SLIDE 1: Aspiration -->
    <section class="slide" style="padding-top: 6rem;">
        <div style="display: flex; align-items: center; gap: 4rem;">
            <div style="flex: 1;">
                <h2 class="slide-headline">Your thinking, captured.<br>Your AI, <em>transformed.</em></h2>
                <div class="slide-body">
                    <p>Go for a walk. Talk through your ideas. By the time you&rsquo;re home, your thoughts are organized, searchable, and available to any AI you use.</p>
                    <p style="font-family: var(--serif); font-size: 1.3rem; color: var(--fg); margin-top: 1rem;">This is Parachute.</p>
                </div>
            </div>
            <div style="flex: 0 0 auto;">
                <img src="/nvc/images/pendant-worn.png" alt="Parachute pendant worn on a walk" style="width: 320px; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,0.08);">
            </div>
        </div>
    </section>

    <!-- SLIDE 2: The Product -->
    <section class="slide">
        <div style="display: flex; align-items: center; gap: 4rem;">
            <div style="flex: 1;">
                <div class="slide-label">The Product</div>
                <h2 class="slide-headline">Parachute Daily.<br>Just talk.</h2>
                <div class="slide-body">
                    <p>A voice-first journal. Speak into a wearable pendant or your phone &mdash; wherever thinking happens.</p>
                    <p>Your notes become structured knowledge that <strong>any AI can work with</strong> &mdash; not locked inside one platform.</p>
                </div>
            </div>
            <div style="flex: 0 0 auto;">
                <img src="/nvc/images/pendant-render.png" alt="Parachute pendant" style="width: 240px; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,0.08);">
            </div>
        </div>
    </section>

    <!-- SLIDE 3: The Problem -->
    <section class="slide">
        <div class="slide-label">The Problem</div>
        <h2 class="slide-headline">There&rsquo;s no knowledge layer.</h2>
        <div class="slide-body">
            <p>Every AI stores your context the same way: <strong>one flat text file.</strong> It remembers your name, not six months of your thinking.</p>
            <p>And capture is broken &mdash; to give your AI context, you have to <em>talk to your AI.</em> There&rsquo;s no way to think for yourself and have it become context.</p>
        </div>
    </section>

    <!-- SLIDE 4: How It Works -->
    <section class="slide">
        <div class="slide-label">How It Works</div>
        <h2 class="slide-headline">Spin up a vault. Give any AI a link.</h2>
        <div class="slide-body">
            <p>A personal knowledge graph &mdash; <strong>Notes, Tags, and Links</strong> &mdash; accessible to any AI via MCP, the open standard for connecting AI to tools.</p>
        </div>
        <div class="arch-diagram">
            <div class="arch-spoke">
                <div class="arch-spoke-label">you</div>
                <span class="arch-box">Parachute Daily</span>
                <span class="arch-box">Pendant</span>
                <span class="arch-box">Phone &middot; Web</span>
            </div>
            <div class="arch-connector">&harr;</div>
            <div class="arch-hub">
                <strong>Parachute Vault</strong>
                Notes &middot; Tags &middot; Links
            </div>
            <div class="arch-connector">
                &harr;
                <span class="conn-label">MCP</span>
            </div>
            <div class="arch-spoke right">
                <div class="arch-spoke-label">your AI</div>
                <span class="arch-box">Claude</span>
                <span class="arch-box">ChatGPT</span>
                <span class="arch-box">Gemini</span>
                <span class="arch-box">Any agent</span>
            </div>
        </div>
    </section>

    <!-- SLIDE 5: Competitive Landscape -->
    <section class="slide">
        <div class="slide-label">Competitive Landscape</div>
        <h2 class="slide-headline">Everyone builds one piece.<br>Nobody connects them.</h2>
        <div class="landscape">
            <div class="landscape-quadrant">
                <div class="quad-label">Note apps &mdash; great capture, no AI</div>
                <div class="quad-names">Obsidian<br>Apple Notes<br>Notion</div>
            </div>
            <div class="landscape-quadrant">
                <div class="quad-label">AI platforms &mdash; smart, but siloed</div>
                <div class="quad-names">ChatGPT<br>Gemini<br>Claude</div>
            </div>
            <div class="landscape-quadrant">
                <div class="quad-label">Knowledge tools &mdash; power users only</div>
                <div class="quad-names">Tana<br>Roam<br>Mem</div>
            </div>
            <div class="landscape-quadrant ours">
                <div class="quad-label">Parachute &mdash; knowledge layer for all AI</div>
                <div class="quad-names">Open &middot; Portable &middot; Agent-native<br>Works with every AI, not instead of one</div>
            </div>
        </div>
    </section>

    <!-- SLIDE 6: Who Uses This -->
    <section class="slide">
        <div class="slide-label">Real-World Usage</div>
        <h2 class="slide-headline">For anyone who thinks.</h2>
        <div class="persona-row">
            <div class="persona-card">
                <div class="persona-who">The Thinker</div>
                <div class="persona-how">Goes for a morning walk, talks through ideas. Their AI assistant already knows what they were mulling over yesterday.</div>
            </div>
            <div class="persona-card">
                <div class="persona-who">The Professional</div>
                <div class="persona-how">Voice-notes after every meeting. Months of institutional context, searchable by any tool &mdash; never trapped in one app.</div>
            </div>
            <div class="persona-card">
                <div class="persona-who">The Enterprise</div>
                <div class="persona-how">A departing team member records three days of knowledge transfer. Their expertise lives on in a structured, queryable vault.</div>
            </div>
        </div>
    </section>

    <!-- SLIDE 7: Context Compounds -->
    <section class="slide">
        <div class="slide-label">The Moat</div>
        <h2 class="slide-headline">Context compounds.</h2>
        <div class="slide-body">
            <p>Every note builds a richer graph. The longer you use it, the more valuable it becomes &mdash; and the harder it is to leave.</p>
        </div>
        <div class="flywheel">
            <div class="fw-step"><span class="fw-num">01</span> Capture thoughts in Daily</div>
            <div class="fw-step"><span class="fw-num">02</span> Build months of personal context</div>
            <div class="fw-step"><span class="fw-num">03</span> Connect any AI via MCP</div>
            <div class="fw-step"><span class="fw-num">04</span> AI already knows you</div>
            <div class="fw-step final"><span class="fw-num">&rarr;</span> Switching cost through genuine value</div>
        </div>
        <div class="slide-body">
            <p style="margin-top: 1rem; font-size: 0.95rem;">Open source &middot; Local-first &middot; Public Benefit Corporation.<br>Your data is portable, exportable, self-hostable.</p>
        </div>
    </section>

    <!-- SLIDE 8: Business Model + Market -->
    <section class="slide">
        <div style="display: flex; gap: 4rem; align-items: flex-start;">
            <div style="flex: 1;">
                <div class="slide-label">Business Model</div>
                <h2 class="slide-headline">The $2&ndash;10 add-on<br>to every AI subscription.</h2>
                <div class="tier-table">
                    <div class="tier-row">
                        <div class="tier-price">Free</div>
                        <div class="tier-body"><strong>Offline journal</strong> &mdash; zero hosting cost</div>
                    </div>
                    <div class="tier-row">
                        <div class="tier-price">$2<span>/mo</span></div>
                        <div class="tier-body"><strong>Cloud sync + MCP</strong> &mdash; any AI</div>
                    </div>
                    <div class="tier-row">
                        <div class="tier-price">$5<span>/mo</span></div>
                        <div class="tier-body"><strong>Cloud transcription</strong> &mdash; better accuracy</div>
                    </div>
                    <div class="tier-row tier-highlight">
                        <div class="tier-price">$10<span>/mo</span></div>
                        <div class="tier-body"><strong>AI reflections + synthesis</strong></div>
                    </div>
                    <div class="tier-row">
                        <div class="tier-price">$100</div>
                        <div class="tier-body"><strong>Parachute Pendant</strong> &mdash; hardware</div>
                    </div>
                </div>
            </div>
            <div style="flex: 0 0 auto; padding-top: 5rem;">
                <div class="stat-row" style="margin: 0;">
                    <div class="stat">
                        <div class="stat-num">100M+</div>
                        <div class="stat-label">people already pay<br>$20+/mo for AI</div>
                    </div>
                </div>
                <div class="stat-row" style="margin-top: 1rem;">
                    <div class="stat">
                        <div class="stat-num">$50B+</div>
                        <div class="stat-label">agentic AI market<br>by 2030</div>
                    </div>
                    <div class="stat">
                        <div class="stat-num">44%</div>
                        <div class="stat-label">CAGR</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SLIDE 9: Go-to-Market -->
    <section class="slide">
        <div class="slide-label">Go-to-Market</div>
        <h2 class="slide-headline">Multiple channels.<br>One community.</h2>
